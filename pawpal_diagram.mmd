classDiagram
    class Owner {
        +String name
        +int available_minutes
        +dict preferences
        +add_pet(pet) None
        +get_available_time() int
    }

    class Pet {
        +String name
        +String species
        +int age
        +list special_needs
        +has_special_needs() bool
        +get_task_list() list
    }

    class Task {
        +String title
        +int duration_minutes
        +String priority
        +String category
        +bool is_required
        +String notes
        +is_high_priority() bool
        +get_summary() str
    }

    class Scheduler {
        +Owner owner
        +Pet pet
        +list tasks
        +int available_minutes
        +rank_tasks() list
        +fits_in_budget(task) bool
        +generate_plan() DailyPlan
        +explain_plan(plan) str
    }

    class DailyPlan {
        +list scheduled_tasks
        +list skipped_tasks
        +int total_duration
        +String explanation
        +get_summary() str
        +display() None
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler --> Owner : uses
    Scheduler --> Pet : uses
    Scheduler --> Task : ranks
    Scheduler --> DailyPlan : produces
